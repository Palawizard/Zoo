<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Zoo.Desktop.App"
             RequestedThemeVariant="Dark">
    <Application.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#EAF1F6" />
        <SolidColorBrush x:Key="MutedBrush" Color="#99AABC" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0F1722" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#132132" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#27384D" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2EC4B6" />
        <SolidColorBrush x:Key="AccentWarmBrush" Color="#7CC6FE" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#1B2C3C" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF6B6B" />
        <SolidColorBrush x:Key="InfoBrush" Color="#5AA9FF" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontFamily" Value="Inter" />
        </Style>

        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BoxShadow" Value="0 22 50 0 #60000000" />
        </Style>

        <Style Selector="Border.panelAccent">
            <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="#31475E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style Selector="Border.metricCard">
            <Setter Property="Background" Value="#13202D" />
            <Setter Property="BorderBrush" Value="#243649" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style Selector="Border.listCard">
            <Setter Property="Background" Value="#162433" />
            <Setter Property="BorderBrush" Value="#27384D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style Selector="Border.softCard">
            <Setter Property="Background" Value="#18283A" />
            <Setter Property="BorderBrush" Value="#294055" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style Selector="TextBlock.eyebrow">
            <Setter Property="Foreground" Value="{DynamicResource AccentWarmBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.panelTitle">
            <Setter Property="FontFamily" Value="Inter" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
        </Style>

        <Style Selector="TextBlock.metricValue">
            <Setter Property="FontFamily" Value="Georgia" />
            <Setter Property="FontSize" Value="32" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="#081418" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,10" />
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#162433" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="16,10" />
        </Style>

        <Style Selector="Button.compact">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#2B171B" />
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="#6A3038" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#162433" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="MinHeight" Value="42" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#162433" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="MinHeight" Value="42" />
        </Style>

        <Style Selector="TabItem">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
    </Application.Styles>
</Application>
