<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Zoo.Desktop.App"
             RequestedThemeVariant="Light">
    <Application.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#1D231F" />
        <SolidColorBrush x:Key="MutedBrush" Color="#5E675F" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F8F5EF" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#EEF4EC" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D9D3C7" />
        <SolidColorBrush x:Key="AccentBrush" Color="#1F6A4E" />
        <SolidColorBrush x:Key="AccentWarmBrush" Color="#B86A2D" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#DEEADF" />
        <SolidColorBrush x:Key="DangerBrush" Color="#A33D3D" />
        <SolidColorBrush x:Key="InfoBrush" Color="#2B7285" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BoxShadow" Value="0 18 48 0 #18000000" />
        </Style>

        <Style Selector="Border.panelAccent">
            <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="#C6DAC9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style Selector="Border.metricCard">
            <Setter Property="Background" Value="#FFFDFC" />
            <Setter Property="BorderBrush" Value="#D9D3C7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style Selector="Border.listCard">
            <Setter Property="Background" Value="#FFFDFC" />
            <Setter Property="BorderBrush" Value="#E4DDD1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style Selector="Border.softCard">
            <Setter Property="Background" Value="#FFFDFC" />
            <Setter Property="BorderBrush" Value="#E4DDD1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style Selector="TextBlock.eyebrow">
            <Setter Property="Foreground" Value="{DynamicResource AccentWarmBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="TextBlock.panelTitle">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
        </Style>

        <Style Selector="TextBlock.metricValue">
            <Setter Property="FontFamily" Value="Georgia" />
            <Setter Property="FontSize" Value="32" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,10" />
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#FFFDFC" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
        </Style>

        <Style Selector="Button.compact">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#FFF4F3" />
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="#E8C1BE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FFFDFC" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="42" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#FFFDFC" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="42" />
        </Style>

        <Style Selector="TabItem">
            <Setter Property="Padding" Value="14,8" />
        </Style>
    </Application.Styles>
</Application>
